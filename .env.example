# ============================================================
# ServerlessKit — Environment Variables
# Copy this file to .env.local and fill in the values.
# NEVER commit .env.local to source control.
# ============================================================

# ── AWS Configuration ─────────────────────────────────────
AWS_REGION=us-east-1
AWS_PROFILE=default

# DynamoDB table name (output from CloudFormation stack)
TABLE_NAME=serverless-kit-items-dev

# CORS allowed origin (use * for local dev, restrict in prod)
CORS_ORIGIN=http://localhost:5173

# ── Cognito (from CloudFormation outputs) ─────────────────
VITE_COGNITO_USER_POOL_ID=us-east-1_XXXXXXXXX
VITE_COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx
VITE_COGNITO_REGION=us-east-1

# ── API Gateway (from CloudFormation outputs) ─────────────
VITE_API_URL=https://xxxxxxxxxx.execute-api.us-east-1.amazonaws.com/dev

# For local SAM development, override with local endpoint:
# VITE_API_URL=http://localhost:3000

# ── Frontend Build ─────────────────────────────────────────
VITE_APP_NAME=ServerlessKit
VITE_APP_ENV=development
